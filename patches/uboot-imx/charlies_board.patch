+  (PAD_CTL_PKE | PAD_CTL_PUE | PAD_CTL_PUS_100K_UP | PAD_CTL_SPEED_MED |       \
+   PAD_CTL_DSE_40ohm | PAD_CTL_HYS | PAD_CTL_ODE)
