+  /* Set the iomux */
+  imx_iomux_v3_setup_multiple_pads(quadspi_pads, ARRAY_SIZE(quadspi_pads));
+#endif
+  /* Set the clock */
+  enable_qspi_clk(0);
+
+  return 0;
+}
+#endif
